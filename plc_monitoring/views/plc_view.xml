<odoo>
    <!-- BASE VIEW -->
    <record id="view_base_production_counter" model="ir.ui.view">
        <field name="name">base.production.counter</field>
        <field name="model">ir.ui.view</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <div class="o_card">
                            <h2>Line Stay</h2>
                            <a href="/web#action=action_plc_data">View Counter</a>
                        </div>
                        <div class="o_card">
                            <h2>NF</h2>
                            <p>Description or additional info about NF.</p>
                        </div>
                        <div class="o_card">
                            <h2>NC</h2>
                            <p>Description or additional info about NC.</p>
                        </div>
                        <div class="o_card">
                            <h2>Spot Welding</h2>
                            <p>Description or additional info about Spot Welding.</p>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_base_production_counter" model="ir.actions.act_window">
        <field name="name">Production Counter</field>
        <field name="res_model">ir.ui.view</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_base_production_counter"/>
    </record>

    <!-- MENU -->
    <menuitem id="menu_base_production_counter" 
              name="Production Counter" 
              action="action_base_production_counter" 
              sequence="10"/>

    <!-- Testing Github Action -->
</odoo>